{
  "name": "shadow-inbox",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "^54.0.35",
    "expo-auth-session": "~7.0.11",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/react": "~19.1.10",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "imap": "^0.8.19",
    "mailparser": "^3.9.11",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "ios:dev": "expo run:ios",
    "android": "expo run:android",
    "android:dev": "expo run:android",
    "web": "expo start --web",
    "fetch-notifications": "node scripts/syncKnowledgeBase.js && node scripts/fetchNotifications.js",
    "email-relay": "node scripts/syncKnowledgeBase.js && node scripts/emailRelay.js",
    "fetch-daemon": "node scripts/syncKnowledgeBase.js && node scripts/fetchDaemon.js",
    "sync:knowledge-base": "node scripts/syncKnowledgeBase.js",
    "google:oauth-config": "node scripts/printGoogleOAuthConfig.js",
    "prestart": "node scripts/syncKnowledgeBase.js",
    "dev:backend": "concurrently --names relay,daemon --prefix-colors blue,magenta \"npm run email-relay\" \"npm run fetch-daemon\"",
    "build:ios": "eas build --profile development --platform ios",
    "build:android": "eas build --profile development --platform android"
  },
  "overrides": {
    "expo-font": "14.0.12"
  },
  "private": true
}
