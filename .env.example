# IMAP (fetch-notifications / fetch daemon)
IMAP_USER=your@gmail.com
IMAP_PASSWORD=your-gmail-app-password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# OpenAI — server-side only (Railway). Do NOT put keys in EXPO_PUBLIC_* vars.
OPENAI_API_KEY=your_openai_api_key
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
# Per-user daily caps (public accounts)
AI_DAILY_TRIAGE_LIMIT=25
AI_DAILY_LLM_LIMIT=10
AI_DAILY_EMBEDDING_LIMIT=15
# Global pool caps (all public users combined)
AI_GLOBAL_DAILY_TRIAGE_LIMIT=100
AI_GLOBAL_DAILY_LLM_LIMIT=40
AI_GLOBAL_DAILY_EMBEDDING_LIMIT=60
AI_LIMIT_EXEMPT_ACCOUNT_KEYS=personal

EXPO_PUBLIC_USER_EMAIL=your@gmail.com

# SMTP (email relay)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# Optional crash reporting (mobile app)
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Mobile app → backend API (production Railway relay)
EXPO_PUBLIC_EMAIL_RELAY_URL=https://shadow-inbox-production.up.railway.app
# Local dev fallback (Mac Mini on same Wi‑Fi): http://192.168.x.x:3000

# Ops Console admin API — set the same secret on Railway (ADMIN_SECRET) and in the app
ADMIN_SECRET=your_long_random_admin_secret
EXPO_PUBLIC_ADMIN_TOKEN=your_long_random_admin_secret

# Firebase Android push (FCM) — do NOT commit the real file
# 1) Download google-services.json from Firebase Console
# 2) Copy to project root: cp ~/Downloads/google-services.json ./google-services.json
# Template: google-services.json.example

# Supabase (cloud deployment — replaces local JSON for feeds, finances, auto-pilot rules)
# Run backend/db/schema.sql in your Supabase SQL editor first.
# IMPORTANT: use the service_role key on Railway, NOT the anon key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cloud port (Railway/Render/Fly set PORT automatically)
# PORT=3000

# Railway — required for Gmail OAuth sign-in from the mobile app
# GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# OPENAI_API_KEY=your_openai_api_key

# Google OAuth — native Android sign-in (no browser redirect URI)
# 1) Android OAuth client: package com.saintjeromeiii.shadowinbox + debug SHA-1
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com

# 2) Web OAuth client: type "Web application" — required for serverAuthCode exchange
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optional second inbox (work/dev). Omit to use mock seed data for the work account.
# WORK_IMAP_USER=shadowdev@gmail.com
# WORK_IMAP_PASSWORD=your-gmail-app-password
# WORK_IMAP_HOST=imap.gmail.com
# WORK_IMAP_PORT=993
# WORK_SMTP_USER=shadowdev@gmail.com
# WORK_SMTP_PASS=your-gmail-app-password

# Slack + Discord broadcast (Upgrade 2)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# DISCORD_BOT_TOKEN=...
# DISCORD_GUILD_ID=your_guild_id
# DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2
# BROADCAST_DEFAULT_ACCOUNT_KEY=personal
# BROADCAST_ACCOUNT_MAP={"T01234567":"personal"}
