# IMAP (fetch-notifications / fetch daemon)
IMAP_USER=your@gmail.com
IMAP_PASSWORD=your-gmail-app-password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# OpenAI triage
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key
EXPO_PUBLIC_LLM_API_URL=https://api.openai.com/v1/chat/completions
EXPO_PUBLIC_LLM_MODEL=gpt-4o-mini
EXPO_PUBLIC_USER_EMAIL=your@gmail.com

# SMTP (email relay)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# Phone → Mac relay (use your Mac's LAN IP, not localhost)
EXPO_PUBLIC_EMAIL_RELAY_URL=http://192.168.1.164:3000

# Google OAuth — native Android sign-in (no browser redirect URI)
# 1) Android OAuth client: package com.saintjeromeiii.shadowinbox + debug SHA-1
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com

# 2) Web OAuth client: type "Web application" — required for serverAuthCode exchange
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optional second inbox (work/dev). Omit to use mock seed data for the work account.
# WORK_IMAP_USER=shadowdev@gmail.com
# WORK_IMAP_PASSWORD=your-gmail-app-password
# WORK_IMAP_HOST=imap.gmail.com
# WORK_IMAP_PORT=993
# WORK_SMTP_USER=shadowdev@gmail.com
# WORK_SMTP_PASS=your-gmail-app-password
